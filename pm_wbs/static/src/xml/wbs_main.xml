<templates xml:space="preserve">

<t t-name="pm_wbs.WBSMainTemplate">

<div class="wbs-container">

    <h2 class="mb-3">WBS Planning</h2>

    <!-- SELECT PROJECT -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <!-- LEFT SIDE -->
        <div class="d-flex gap-3 align-items-center">

            <select class="form-control w-25" t-on-change="selectProject">
                <option value="">-- Pilih Project --</option>
                <t t-foreach="state.projects" t-as="p" t-key="p.id">
                    <option t-att-value="p.id">
                        <t t-esc="p.name"/>
                    </option>
                </t>
            </select>

            <!-- 🔥 ADD TASK TETAP DI KIRI -->
            <button class="btn btn-primary btn-sm px-3 d-flex align-items-center gap-2"
                    t-on-click="addTask"
                    t-if="state.selectedProject">
                <i class="fa fa-plus"/>
                Add Task
            </button>

        </div>

        <!-- RIGHT SIDE -->
        <div class="d-flex gap-2">

            <!-- EXPORT EXCEL -->
            <button class="btn btn-success btn-sm px-3 d-flex align-items-center gap-2"
                    t-if="state.selectedProject"
                    t-on-click="exportExcel">
                <i class="fa fa-file-excel-o"/>
                Excel
            </button>

            <!-- PRINT PDF -->
            <button class="btn btn-outline-primary btn-sm px-3 d-flex align-items-center gap-2"
                    t-if="state.selectedProject"
                    t-on-click="printPDF">
                <i class="fa fa-file-pdf-o"/>
                PDF
            </button>

        </div>

    </div>

    <!-- TABLE -->
    <div class="table-container"
         t-if="state.selectedProject and state.tasks"
         style="height: calc(100vh - 160px); overflow-x: auto; overflow-y: auto;">

        <table class="table table-bordered table-sm align-middle"
           style="min-width: max-content;">

            <!-- ================= HEADER ================= -->
            <thead>

                <tr>
                    <th style="min-width:70px;">WBS</th>
                    <th style="min-width:260px;">TASK</th>
                    <th style="min-width:100px;">BOBOT (%)</th>
                    <th style="min-width:70px;">PROG</th>

                    <t t-foreach="state.weeks" t-as="w" t-key="w.date">
                        <th style="min-width:130px;">
                            <div class="fw-bold"><t t-esc="w.label"/></div>
                            <small class="text-muted">
                                <t t-esc="w.date"/> - <t t-esc="w.end_date"/>
                            </small>
                        </th>
                    </t>
                    <th style="min-width:120px;">KETERANGAN</th>
                    <th style="min-width:150px;">ENGINEER</th>
                    <th style="min-width:120px;">START</th>
                    <th style="min-width:120px;">END</th>
                    <th style="min-width:90px;">DETAIL</th>
                </tr>

            </thead>

            <!-- ================= BODY ================= -->
            <tbody>

            <t t-foreach="state.tasks" t-as="task" t-key="task.id">

            <!-- ===== SCH ROW ===== -->
            <tr class="sch-row">

                <!-- WBS -->
                <td rowspan="2" class="fw-bold">
                    <t t-esc="task.wbs"/>
                </td>

                <!-- TASK -->
                <td rowspan="2" class="text-center">
                    <div t-att-style="'padding-left:' + (task.level * 18) + 'px'"
                         class="wbs-indent justify-content-center">

                        <button class="btn btn-sm btn-outline-secondary"
                                t-on-click="addSubTask"
                                t-att-data-id="task.id">+</button>

                        <input type="text"
                               class="form-control form-control-sm text-center"
                               t-att-value="task.name"
                               t-on-change="updateTaskName"
                               t-att-data-id="task.id"/>

                        <button class="btn btn-sm btn-outline-danger"
                                t-on-click="deleteTask"
                                t-att-data-id="task.id"
                                t-att-disabled="task.has_child">🗑</button>
                    </div>
                </td>

                <!-- WEIGHT -->
                <td rowspan="2">
                    <input type="number"
                           class="form-control form-control-sm text-center"
                           t-att-value="task.weight"
                           t-on-change="updateWeight"
                           t-att-data-id="task.id"
                           t-att-disabled="task.has_child"/>
                </td>

                <!-- SCH LABEL -->
                <td>SCH</td>

                <!-- PLAN -->
                <t t-foreach="task.weeks" t-as="cell" t-key="'sch_' + cell.date">
                    <td>
                        <input type="number"
                            step="0.01"
                            class="wbs-input"
                            t-att-value="cell.plan"
                            t-on-change="updatePlanWBS"
                            t-att-data-task="task.id"
                            t-att-data-week="cell.date"
                            t-att-disabled="task.has_child"/>
                    </td>
                </t>

                <td rowspan="2">
                    <t t-if="task.keterangan === 'Done'">
                        <span class="text-success fw-bold">Done</span>
                    </t>
                    <t t-else="">
                        <span t-att-class="task.keterangan &lt; 0 ? 'text-danger fw-bold' : 'text-success fw-bold'">
                            <t t-esc="formatNumber(task.keterangan)"/>%
                        </span>
                    </t>
                </td>

                <td rowspan="2">
                    <select class="form-control form-control-sm text-center"
                            t-att-data-id="task.id"
                            t-on-change="updatePIC"
                            t-att-disabled="task.has_child">

                        <option value="">-- Pilih Engineer --</option>

                        <t t-foreach="state.users" t-as="u" t-key="u.id">
                            <option t-att-value="u.id"
                                    t-att-selected="u.id === task.pic_id">
                                <t t-esc="u.name"/>
                            </option>
                        </t>

                    </select>
                </td>

                <!-- 🔥 START -->
                <td rowspan="2">
                    <input type="date"
                        class="form-control form-control-sm text-center"
                        t-att-value="task.start_date || ''"
                        t-on-change="updateStartDate"
                        t-att-data-id="task.id"
                        t-att-disabled="task.has_child"/>
                </td>

                <!-- 🔥 END -->
                <td rowspan="2">
                    <input type="date"
                        class="form-control form-control-sm text-center"
                        t-att-value="task.end_date || ''"
                        t-on-change="updateEndDate"
                        t-att-data-id="task.id"
                        t-att-disabled="task.has_child"/>
                </td>

                <td rowspan="2" class="text-center">
                    <button class="btn btn-sm btn-outline-primary"
                            t-on-click="() => this.openTask(task.id)">
                        <i class="fa fa-eye"/>
                    </button>
                </td>

            </tr>

            <!-- ===== ACT ROW ===== -->
            <tr class="act-row">

                <!-- ACT LABEL -->
                <td>ACT</td>

                <!-- ACTUAL -->
                <t t-foreach="task.weeks" t-as="cell" t-key="'act_' + cell.date">
                    <td>
                        <input type="number"
                            step="0.01"
                            class="wbs-input"
                            t-att-value="formatNumber(cell.actual)"
                            readonly="1"/>
                    </td>
                </t>

            </tr>

            </t>

            </tbody>

            <!-- ================= FOOTER ================= -->
            <tfoot>

            <tr class="summary-header">

                <td></td> <!-- WBS kosong -->

                <td class="text-start fw-bold">
                    GRAND TOTAL
                </td>

                <td class="fw-bold text-center">
                    <t t-esc="formatNumber(state.total_weight)"/>%
                </td>

                <td></td> <!-- Prog -->

                <t t-foreach="state.weeks" t-as="w" t-key="w.date">
                    <td></td>
                </t>

                <td></td> <!-- Keterangan -->
                <td></td> <!-- Engineer -->
                <td></td> <!-- Start -->
                <td></td> <!-- End -->
                <td></td> <!-- Detail -->

            </tr>

            <!-- SUMMARY ROWS -->
            <t t-foreach="[
                ['TARGET PENCAPAIAN', 'plan'],
                ['TARGET KUMULATIF', 'plan_cum'],
                ['REALISASI PENCAPAIAN', 'actual'],
                ['REALISASI KUMULATIF', 'actual_cum'],
                ['SELISIH (+/-)', 'deviation']
            ]" t-as="row" t-key="row[0]">

                <tr class="summary-row">

    <!-- WBS -->
                    <td></td>

    <!-- LABEL -->
                    <td class="text-start fw-bold">
                        <t t-esc="row[0]"/>
                    </td>

    <!-- KOSONGIN BOBOT -->
                    <td></td>

    <!-- KOSONGIN PROG -->
                    <td></td>

    <!-- WEEK -->
                    <t t-foreach="state.summary" t-as="s" t-key="s.date">
                        <td t-att-class="row[1] == 'deviation' and (s.deviation &lt; 0 ? 'text-danger' : 'text-success')">
                            <t t-esc="formatNumber(s[row[1]])"/>%
                        </td>
                    </t>

    <!-- KOLOM TAMBAHAN -->
                    <td></td> <!-- Keterangan -->
                    <td></td> <!-- Engineer -->
                    <td></td> <!-- Start -->
                    <td></td> <!-- End -->
                    <td></td> <!-- Detail -->

                </tr>

            </t>

            </tfoot>

        </table>

    </div>

</div>

</t>

</templates>