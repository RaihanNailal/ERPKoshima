<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- =========================================
       PLANNED TASK LIST
    ========================================== -->
    <record id="view_pm_task_list_planned" model="ir.ui.view">
        <field name="name">pm.task.list.wbs</field>
        <field name="model">pm.task</field>

        <field name="arch" type="xml">
            <list string="WBS Tasks"
                create="false"
                edit="false">
                <field name="name"/>
                <field name="project_id"/>
                <field name="weight"/>
                <field name="progress"/>
                <field name="remaining_progress"/>
            </list>
        </field>
    </record>


    <!-- =========================================
       ISSUE TASK LIST
    ========================================== -->
    <record id="view_pm_task_list_issue" model="ir.ui.view">
        <field name="name">pm.task.list.issue</field>
        <field name="model">pm.task</field>

        <field name="arch" type="xml">
            <list string="Issue Tasks"
                create="false"
                edit="false">
                <field name="name"/>
                <field name="project_id"/>
                <field name="status"/>
            </list>
        </field>
    </record>


    <!-- =========================================
       KANBAN
    ========================================== -->
    <record id="view_pm_task_kanban" model="ir.ui.view">
        <field name="name">pm.task.kanban</field>
        <field name="model">pm.task</field>

        <field name="arch" type="xml">
            <kanban create="false">
                <field name="name"/>
                <field name="project_id"/>
                <field name="is_issue_task"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">

                            <strong>
                                <field name="name"/>
                            </strong>

                            <div>
                                <field name="project_id"/>
                            </div>

                            <t t-if="record.is_issue_task and record.is_issue_task.raw_value">
                                <span class="badge bg-warning">
                                    Issue Task
                                </span>
                            </t>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>



    <!-- =========================================
       FORM ENGINEER
    ========================================== -->
    <record id="view_pm_task_form_engineer"
            model="ir.ui.view">

        <field name="name">pm.task.form.engineer</field>
        <field name="model">pm.task</field>
        <field name="priority">100</field>

        <field name="arch" type="xml">
            <form string="Task Engineer">
                <sheet>

                    <!-- INFO -->
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="project_id" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                        <field name="pic_id" readonly="1"/>

                        <field name="issue_source_task_id"
                               string="Related Task"
                               readonly="1"
                               invisible="not is_issue_task"
                               options="{'no_open': True, 'no_create': True}"/>

                        <field name="corrective_action"
                                widget="text"
                                invisible="not is_issue_task"
                                readonly="status == 'done'"/>
                    </group>


                    <!-- NORMAL TASK ONLY -->
                    <group string="Progress Info"
                           invisible="is_issue_task">

                        <field name="weight" readonly="1"/>
                        <field name="progress" readonly="1"/>
                        <field name="remaining_progress"
                               readonly="1"/>

                    </group>


                    <group invisible="is_issue_task">
                        <field name="current_week_label"
                               readonly="1"/>
                    </group>


                    <group string="Input Progress Minggu Ini"
                           invisible="is_issue_task">

                        <field name="actual_input"
                               options="{'format': false}"/>
                    </group>

                    <group invisible="is_issue_task">
                        <button name="action_create_issue"
                                type="object"
                                string="Raise Issue"
                                class="btn btn-danger"/>
                    </group>

                    <group string="DAILY NOTES"
                        col="1"
                        invisible="is_issue_task">

                        <field name="note_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="note"/>
                                <field name="user_id"
                                    readonly="1"/>
                                <field name="create_date"
                                    readonly="1"/>
                            </list>
                        </field>

                    </group>

                   <!-- ================= ISSUE BEFORE ================= -->
                    <group string="Dokumentasi Issue (Before)"
                        invisible="not is_issue_task">

                        <field name="issue_photo_html"
                            readonly="1"
                            nolabel="1"/>

                    </group>


                    <!-- ================= ISSUE AFTER ================= -->
                    <group string="Dokumentasi Issue (After)"
                        invisible="not is_issue_task"
                        col="1">

                        <field name="photo_ids" nolabel="1">

                            <kanban>
                                <field name="image"/>
                                <field name="image_name"/>
                                <field name="note"/>
                                <field name="user_id"/>
                                <field name="create_date"/>

                                <templates>
                                    <t t-name="card">
                                        <div style="
                                            width:150px;
                                            padding:6px;
                                            background:white;
                                            border:1px solid #ddd;
                                            border-radius:8px;
                                            text-align:center;
                                        ">

                                            <!-- IMAGE -->
                                            <img t-if="record.image.raw_value"
                                                t-att-src="'/web/image/pm.task.photo/' + record.id.raw_value + '/image'"
                                                alt="After Documentation"
                                                style="
                                                    width:130px;
                                                    height:80px;
                                                    object-fit:cover;
                                                    border-radius:6px;
                                                "/>

                                            <!-- 🔥 CAPTION -->
                                            <div style="margin-top:6px; font-weight:500;">
                                                <field name="note"/>
                                            </div>

                                            <!-- 🔥 USER -->
                                            <div style="font-size:11px; color:#666;">
                                                <field name="user_id"/>
                                            </div>

                                            <!-- 🔥 TIME -->
                                            <div style="font-size:11px; color:#999;">
                                                <field name="create_date"/>
                                            </div>

                                        </div>
                                    </t>
                                </templates>
                            </kanban>

                        </field>

                    </group>


                    <!-- ================= WBS TASK ONLY ================= -->
                    <group string="DOKUMENTASI PEKERJAAN"
                        invisible="is_issue_task"
                        col="1">

                        <field name="photo_ids" nolabel="1">

                            <kanban>
                                <field name="image"/>
                                <field name="image_name"/>
                                <field name="note"/>
                                <field name="user_id"/>
                                <field name="create_date"/>

                                <templates>
                                    <t t-name="card">
                                        <div style="
                                            width:150px;
                                            padding:6px;
                                            background:white;
                                            border:1px solid #ddd;
                                            border-radius:8px;
                                            text-align:center;
                                        ">

                                            <!-- IMAGE -->
                                            <img t-if="record.image.raw_value"
                                                t-att-src="'/web/image/pm.task.photo/' + record.id.raw_value + '/image'"
                                                alt="Task Documentation"
                                                style="
                                                    width:130px;
                                                    height:80px;
                                                    object-fit:cover;
                                                    border-radius:6px;
                                                "/>

                                            <!-- 🔥 CAPTION -->
                                            <div style="margin-top:6px; font-weight:500;">
                                                <field name="note"/>
                                            </div>

                                            <!-- 🔥 USER -->
                                            <div style="font-size:11px; color:#666;">
                                                <field name="user_id"/>
                                            </div>

                                            <!-- 🔥 TIME -->
                                            <div style="font-size:11px; color:#999;">
                                                <field name="create_date"/>
                                            </div>

                                        </div>
                                    </t>
                                </templates>
                            </kanban>

                        </field>

                    </group>

                    <!-- ISSUE TASK ONLY -->
                    <button name="action_mark_done"
                            type="object"
                            string="Done"
                            class="btn-success"
                            invisible="not is_issue_task or status=='done'"/>

                </sheet>
            </form>
        </field>
    </record>



    <!-- =========================================
       ACTION PLANNED TASKS
    ========================================== -->
    <record id="action_pm_task_planned"
            model="ir.actions.act_window">

        <field name="name">WBS Tasks</field>
        <field name="res_model">pm.task</field>
        <field name="view_mode">list,kanban,form</field>

        <field name="context">
        {
        'create': False
        }
        </field>

        <field name="view_id"
               ref="view_pm_task_list_planned"/>

        <field name="domain">
            [
                ('child_ids','=',False),
                ('is_issue_task','=',False)
            ]
        </field>

    </record>



    <!-- =========================================
       ACTION ISSUE TASKS
    ========================================== -->
    <record id="action_pm_task_issue"
            model="ir.actions.act_window">

        <field name="name">Issue Tasks</field>
        <field name="res_model">pm.task</field>
        <field name="view_mode">list,kanban,form</field>

        <field name="context">
        {
        'create': False
        }
        </field>

        <field name="view_id"
               ref="view_pm_task_list_issue"/>

        <field name="domain">
            [
                ('is_issue_task','=',True)
            ]
        </field>

    </record>


    <menuitem id="menu_pm_tasks_root"
            name="My Tasks"
            parent="pm_project.menu_pm_root"
            sequence="20"
            groups="base.group_system,pm_core.group_pm_director,pm_core.group_pm_engineer"/>



    <!-- ================= WBS TASKS ================= -->
    <menuitem id="menu_pm_planned_tasks"
            name="WBS Tasks"
            parent="menu_pm_tasks_root"
            action="action_pm_task_planned"
            sequence="1"
            groups="base.group_system,pm_core.group_pm_director,pm_core.group_pm_engineer"/>



    <!-- ================= ISSUE TASKS ================= -->
    <menuitem id="menu_pm_issue_tasks"
            name="Issue Tasks"
            parent="menu_pm_tasks_root"
            action="action_pm_task_issue"
            sequence="2"
            groups="base.group_system,pm_core.group_pm_director,pm_core.group_pm_engineer"/>

</data>
</odoo>