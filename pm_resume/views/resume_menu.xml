<odoo>

    <!-- ===================================== -->
    <!-- RESUME TREE -->
    <!-- ===================================== -->

       <record id="view_pm_project_resume_tree"
              model="ir.ui.view">

              <field name="name">pm.project.resume.tree</field>

              <field name="model">pm.project</field>

              <field name="arch"
                     type="xml">

              <list create="false"
                     edit="false"
                     delete="false"
                     open_form_view="true"
                     default_order="deviation asc"
                     class="o_pm_resume_list">

                     <!-- ===================================== -->
                     <!-- PROJECT -->
                     <!-- ===================================== -->

                     <field name="name"
                            string="Project"
                            optional="show"/>

                     <!-- ===================================== -->
                     <!-- LEADER -->
                     <!-- ===================================== -->

                     <field name="leader_id"
                            string="Leader"
                            widget="many2one_avatar_user"
                            optional="show"/>

                     <!-- ===================================== -->
                     <!-- PLAN -->
                     <!-- ===================================== -->

                     <field name="weekly_plan"
                            string="Plan %"
                            widget="progressbar"
                            optional="show"/>

                     <!-- ===================================== -->
                     <!-- ACTUAL -->
                     <!-- ===================================== -->

                     <field name="weekly_actual"
                            string="Actual %"
                            widget="progressbar"
                            optional="show"/>

                     <!-- ===================================== -->
                     <!-- DEVIATION -->
                     <!-- ===================================== -->

                     <field name="deviation"
                            string="Deviation %"
                            optional="show"
                            decoration-danger="deviation &lt; 0"
                            decoration-success="deviation &gt;= 0"/>

                     <!-- ===================================== -->
                     <!-- REMAINING -->
                     <!-- ===================================== -->

                     <field name="remaining_days"
                            string="Days Left"
                            optional="show"
                            decoration-danger="remaining_days &lt;= 7"
                            decoration-warning="remaining_days &gt; 7 and remaining_days &lt;= 30"/>

                     <!-- ===================================== -->
                     <!-- ACTION -->
                     <!-- ===================================== -->

                     <button
                     name="action_open_project_issues"
                     type="object"
                     string="Issues"
                     icon="fa-exclamation-circle"
                     class="btn btn-sm btn-primary"/>

              </list>

              </field>

       </record>


    <!-- ===================================== -->
    <!-- SEARCH VIEW -->
    <!-- ===================================== -->

       <record id="view_pm_project_resume_search"
                     model="ir.ui.view">

              <field name="name">pm.project.resume.search</field>

              <field name="model">pm.project</field>

              <field name="arch"
                     type="xml">

                     <search>

                     <filter name="delayed"
                            string="Delayed"
                            domain="[('deviation','&lt;',0)]"/>

                     <filter name="healthy"
                            string="Healthy"
                            domain="[('deviation','&gt;=',0)]"/>

                     <separator/>

                     <filter name="deadline"
                            string="Deadline &lt; 7 Days"
                            domain="[('remaining_days','&lt;=',7)]"/>

                     </search>

              </field>

       </record>


    <!-- ===================================== -->
    <!-- ACTION -->
    <!-- ===================================== -->

       <record id="action_pm_resume_list"
                     model="ir.actions.act_window">

                     <field name="name">Project Portfolio Resume</field>

                     <field name="res_model">pm.project</field>

                     <field name="view_mode">list</field>

                     <field name="view_id"
                            ref="view_pm_project_resume_tree"/>

                     <field name="search_view_id"
                            ref="view_pm_project_resume_search"/>

       </record>       


    <!-- ===================================== -->
    <!-- MENU -->
    <!-- ===================================== -->

       <menuitem
              id="menu_pm_resume"
              name="Project Resume"
              parent="pm_project.menu_pm_root"
              action="action_pm_resume_list"
              sequence="14"
              groups="base.group_system,pm_core.group_pm_director"/>

</odoo>