<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= KANBAN ================= -->
    <record id="view_pm_project_kanban" model="ir.ui.view">
        <field name="name">pm.project.kanban</field>
        <field name="model">pm.project</field>
        <field name="arch" type="xml">

            <kanban default_group_by="status"
                    expand="1"
                    class="o_kanban_small_column o_kanban_project"
                    group_create="false"
                    group_delete="false">

                <field name="name"/>
                <field name="status"/>
                <field name="leader_id"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_card p-3">

                            <!-- HEADER -->
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>

                                <span class="badge bg-light text-dark">
                                    <field name="status"/>
                                </span>
                            </div>

                            <!-- BODY -->
                            <div class="mb-2">
                                <small class="text-muted">Project Leader</small>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <field name="leader_id" widget="many2one_avatar_user"/>
                                    <span><field name="leader_id"/></span>
                                </div>
                            </div>

                            <!-- FOOTER -->
                            <div class="d-flex justify-content-between mt-3">

                                <div>
                                    <button type="object"
                                            name="action_archive_project"
                                            class="btn btn-sm btn-outline-warning"
                                            invisible="active == False">
                                        Archive
                                    </button>

                                    <button type="object"
                                            name="action_restore_project"
                                            class="btn btn-sm btn-outline-success"
                                            invisible="active == True">
                                        Restore
                                    </button>
                                </div>

                                <button type="object"
                                        name="action_delete_project"
                                        class="btn btn-sm btn-outline-danger"
                                        confirm="Hapus project ini?">
                                    Delete
                                </button>

                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>

        </field>
    </record>

    <!-- ================= LIST ================= -->
    <record id="view_pm_project_tree" model="ir.ui.view">
        <field name="name">pm.project.list</field>
        <field name="model">pm.project</field>
        <field name="arch" type="xml">
            <list string="Projects">

                <field name="name"/>
                <field name="leader_id" widget="many2one_avatar_user"/>
                <field name="start_date"/>
                <field name="end_date"/>

                <field name="status" widget="badge"
                    decoration-info="status == 'draft'"
                    decoration-warning="status == 'progres'"
                    decoration-success="status == 'done'"/>

            </list>
        </field>
    </record>

    <record id="view_pm_project_search" model="ir.ui.view">
        <field name="name">pm.project.search</field>
        <field name="model">pm.project</field>
        <field name="arch" type="xml">
            <search>

                <field name="name"/>

                <filter string="Active"
                        name="active"
                        domain="[('active','=',True)]"/>

                <filter string="Archived"
                        name="archived"
                        domain="[('active','=',False)]"/>

                <separator/>

                <filter string="All Projects"
                        name="all"
                        domain="[]"
                        context="{'active_test': False}"/>

            </search>
        </field>
    </record>

    <!-- ================= ACTION ================= -->
    <record id="action_my_project_list" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">pm.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_pm_project_search"/>
        <field name="context">{'active_test': True}</field>
    </record>

    <!-- ================= FORM ================= -->
    <record id="view_pm_project_form" model="ir.ui.view">
        <field name="name">pm.project.form</field>
        <field name="model">pm.project</field>
        <field name="arch" type="xml">

            <form>

                <!-- HEADER -->
                <header>

                    <!-- START -->
                    <button name="action_button_start"
                            string="Start Project"
                            type="object"
                            class="btn btn-primary"
                            icon="fa-play"
                            invisible="status != 'draft'"/>

                    <!-- DONE -->
                    <button name="action_button_done"
                            string="Mark as Done"
                            type="object"
                            class="btn btn-success"
                            icon="fa-check"
                            invisible="status != 'progres'"
                            confirm="Yakin project sudah selesai?"/>

                    <!-- STATUS BAR -->
                    <field name="status"
                        widget="statusbar"
                        statusbar_visible="draft,progres,done"/>

                </header>

                <sheet>

                    <!-- TITLE -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nama Project..."/>
                        </h1>
                        <div class="text-muted mt-1">
                            Project Code:
                            <strong>
                                <field name="project_code" placeholder="Code???"/>
                            </strong>
                        </div>
                    </div>

                    <group>

                        <!-- KIRI -->
                        <group string="Project Info">

                            <field name="client_id" widget="many2one_avatar_user"/>
                            <field name="leader_id" widget="many2one_avatar_user"/>

                            <field name="start_date"/>
                            <field name="end_date"/>

                        </group>

                        <!-- KANAN -->
                        <group string="Detail">

                            <field name="vendor"/>
                            <field name="po_number"/>

                        </group>

                    </group>

                    <!-- FULL WIDTH DESCRIPTION -->
                    <group>
                        <field name="project_location" colspan="4" placeholder="Lokasi project..."/>
                        <field name="description" colspan="4" placeholder="Deskripsi project..."/>
                    </group>

                    <!-- LOGO SECTION -->
                    <group string="Logo">

                        <field name="logo_left"
                            widget="image"
                            options="{'size': [120, 60]}"/>

                        <field name="logo_right"
                            widget="image"
                            options="{'size': [160, 80]}"/>

                    </group>

                </sheet>
            </form>

        </field>
    </record>

    <!-- ================= MENU ================= -->
    <menuitem id="menu_pm_root"
        name="Project Management"
        sequence="10"
        groups="base.group_system,pm_core.group_pm_director,pm_core.group_pm_leader,pm_core.group_pm_engineer,pm_core.group_pm_client"/>

    <menuitem id="menu_pm_project"
        name="Projects"
        parent="menu_pm_root"
        action="action_my_project_list"
        sequence="10"
        groups="base.group_system,pm_core.group_pm_director,pm_core.group_pm_leader"/>

</odoo>