<odoo>

    <!-- DIRECTOR -->
    <record id="rule_director_all_projects"
            model="ir.rule">
        <field name="name">
            Director All Projects
        </field>

        <field name="model_id"
               ref="model_pm_project"/>

        <field name="groups"
         eval="[(4,
         ref('pm_core.group_pm_director'))]"/>

        <field name="domain_force">
            [(1,'=',1)]
        </field>
    </record>



    <!-- LEADER -->
    <record id="rule_leader_own_project"
            model="ir.rule">

        <field name="name">
            Leader Own Project
        </field>

        <field name="model_id"
               ref="model_pm_project"/>

        <field name="groups"
         eval="[(4,
         ref('pm_core.group_pm_leader'))]"/>

        <field name="domain_force">
           [('leader_id','=',user.id)]
        </field>

    </record>



    



    <!-- CLIENT -->
    <record id="rule_client_own_project_v2"
            model="ir.rule">

        <field name="name">
           Client Own Project
        </field>

        <field name="model_id"
               ref="model_pm_project"/>

        <field name="groups"
         eval="[(4,
         ref('pm_core.group_pm_client'))]"/>

        <field name="domain_force">
           [('client_id','=',user.id)]
        </field>

    </record>

</odoo>